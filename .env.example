# Application
NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=pos
DB_PASSWORD=pos
DB_NAME=pos
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Security (HMAC) — usado nas próximas sprints
HMAC_SECRET=change-me-in-production-please
HMAC_TIMESTAMP_TOLERANCE_SECONDS=300

# External API — aponta para o mock Fastify do diretório mock-api/
# Em dev fora do Docker: http://localhost:4000
EXTERNAL_API_URL=http://mock-api:4000
EXTERNAL_API_TIMEOUT_MS=3000

# Retry: tentativa inicial + N tentativas adicionais com backoff exponencial + jitter
EXTERNAL_API_RETRY_MAX_ATTEMPTS=2
EXTERNAL_API_RETRY_INITIAL_DELAY_MS=100
EXTERNAL_API_RETRY_MAX_DELAY_MS=1000

# Circuit breaker: abre após N falhas consecutivas, tenta meia-aberto após X ms
EXTERNAL_API_BREAKER_CONSECUTIVE_FAILURES=5
EXTERNAL_API_BREAKER_HALF_OPEN_AFTER_MS=10000

# Bulkhead: limita concorrência (e fila) para evitar saturar pool de conexões
EXTERNAL_API_BULKHEAD_MAX_CONCURRENT=20
EXTERNAL_API_BULKHEAD_MAX_QUEUE=50

# Observability (OpenTelemetry — vars padrão do SDK)
OTEL_SERVICE_NAME=pos-transactions-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# OTEL_SDK_DISABLED=true     # útil em testes / ambientes sem collector
# OTEL_LOG_LEVEL=debug
